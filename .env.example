# ═══ Часпик Транспорт Lite — .env ═══

# ─── App ───
DEBUG=true
SECRET_KEY=change-me-to-random-string

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://chaspik:chaspik@postgres:5432/chaspik

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── Золотая Корона: Keycloak (Informator) ───
# URL токена (замените realm на свой)
KORONA_AUTH_URL=https://auth.transport-card.korona.net/auth/realms/YOUR_REALM/protocol/openid-connect/token
KORONA_CLIENT_ID=your_client_id
KORONA_CLIENT_SECRET=your_client_secret
KORONA_USERNAME=your_username
KORONA_PASSWORD=your_password

# ─── Золотая Корона: Informator API ───
KORONA_API_URL=https://api.transport-card.korona.net/api/tcard-info/1.0

# ─── MAX Bot ───
MAX_BOT_TOKEN=your_max_bot_token

# ─── CORS ───
CORS_ORIGINS=*
